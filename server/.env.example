# Copy this file to .env and fill in your own values.
#
# Code execution runs via Wandbox (https://wandbox.org) — free, keyless,
# no signup, no card. No env var needed for it.

# Optional but recommended: a MongoDB Atlas connection string, so room code
# survives a server restart/redeploy instead of living only in memory.
# Free forever, no card required — see README for the 5-minute setup.
# Accounts (signup/login), invites, teams, and saved sessions ALSO need
# this — those features simply won't work until it's set (everything else
# still runs fine without it).
MONGODB_URI=

# Optional: enables the "Ask AI" coding helper (host-only by default; the
# host can turn it on for everyone in the meeting). Free, no card — get a
# key from Google AI Studio in about a minute, see README for steps.
# If left blank, the Ask AI panel just shows a "not configured" message
# instead of breaking anything else.
GEMINI_API_KEY=

# Signs the login tokens (JWTs) issued by /api/auth/login and
# /api/auth/signup. If left blank, the server generates a random one on
# startup — fine for local dev, but it means everyone gets logged out on
# every restart. For a real deploy, set this to any long random string
# (e.g. run `openssl rand -hex 32`) and keep it the same across restarts.
JWT_SECRET=

# The deployed frontend's URL, e.g. https://your-app.vercel.app
# Leave unset for local development (defaults to allowing any origin).
CLIENT_ORIGIN=
